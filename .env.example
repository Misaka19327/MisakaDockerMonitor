# Storage: sqlite | clickhouse | mysql
STORAGE_TYPE=sqlite

# SQLite
SQLITE_PATH=./data/logs.db

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=docker_monitor

# ClickHouse
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DATABASE=docker_monitor
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Docker socket path (Linux: /var/run/docker.sock, Windows: //./pipe/docker_engine)
DOCKER_SOCKET=/var/run/docker.sock

# Timezone used by the server for explicit timestamp writes and formatting
TIMEZONE=Asia/Shanghai

# Auth
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
JWT_SECRET=change-this-secret
JWT_TTL_SECONDS=86400

# Retain logs on container restart (true/false)
RETAIN_LOGS_ON_RESTART=true

# Server
PORT=3000
HOST=0.0.0.0
